# Verkrijg via @BotFather in Telegram (zie README.md)
TELEGRAM_BOT_TOKEN=

# Jouw eigen Telegram user-ID (bv. via @userinfobot), zodat alleen jij de bot kunt gebruiken
ALLOWED_TELEGRAM_USER_ID=

# Anthropic API key voor de Claude Agent SDK
ANTHROPIC_API_KEY=

# Optioneel — geeft de bot toegang tot je Notion-werkruimte via de officiele
# Notion MCP-server. Maak een "internal integration" op notion.so/my-integrations,
# kopieer het token (begint met ntn_...), en deel de gewenste pagina's/databases met
# die integratie in Notion zelf (Connections). Zonder deze var: geen Notion-tools.
# NOTION_TOKEN=

# Optioneel — standaardwaarden hieronder
# WORKING_DIR=/home/chiel
# CLAUDE_MODEL=claude-sonnet-5
# APPROVAL_TIMEOUT_MS=900000
# SESSION_STORE_PATH=./data/sessions.json
